def make_group_lags(data, group_cols, target_col, lags=[1,2,3], roll_windows=[3,7]):
    df_new = data.copy()
    for lag in lags:
        df_new[f"{target_col}_lag{lag}"] = df_new.groupby(group_cols)[target_col].shift(lag)
    for win in roll_windows:
        df_new[f"{target_col}_rollmean{win}"] = df_new.groupby(group_cols)[target_col].shift(1).rolling(win).mean()
    return df_new

# Apply lag features
